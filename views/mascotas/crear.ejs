<%- include('../partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-success text-white py-4" style="border-radius: 15px 15px 0 0;">
                <h4 class="mb-0 text-center"><i class="fa-solid fa-notes-medical me-2"></i>Nueva Ficha de Paciente</h4>
            </div>
            <div class="card-body p-4">
                
                <% if (typeof errores!== 'undefined') { %>
                    <div class="alert alert-danger shadow-sm border-0 mb-4">
                        <p class="fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Errores de validación:</p>
                        <ul class="mb-0">
                            <% errores.forEach(error => { %>
                                <li><%= error.msg %></li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>

                <form action="/mascotas/crear" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre del Paciente</label>
                        <input type="text" name="nombre" class="form-control" placeholder="Ej: Firulais" 
                               value="<%= typeof datos!== 'undefined'? datos.nombre : '' %>" required>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Especie</label>
                            <select name="especie" class="form-select border-success shadow-sm">
                                <option value="Perro" <%= (typeof datos!== 'undefined' && datos.especie === 'Perro')? 'selected' : '' %>>🐶 Perro</option>
                                <option value="Gato" <%= (typeof datos!== 'undefined' && datos.especie === 'Gato')? 'selected' : '' %>>🐱 Gato</option>
                                <option value="Otro" <%= (typeof datos!== 'undefined' && datos.especie === 'Otro')? 'selected' : '' %>>🐾 Otro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Raza</label>
                            <input type="text" name="raza" class="form-control" placeholder="Ej: Labrador" 
                                   value="<%= typeof datos!== 'undefined'? datos.raza : '' %>" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Edad (Opcional)</label>
                        <input type="text" name="edad" class="form-control" placeholder="Ej: 3 años o 5 meses"
                            value="<%= typeof datos!== 'undefined'? datos.edad : (typeof mascota!== 'undefined'? mascota.edad : '') %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Síntomas (Obligatorio)</label>
                        <textarea name="sintomas" class="form-control" rows="2"
                            required><%= typeof datos!== 'undefined'? datos.sintomas : (typeof mascota!== 'undefined'? mascota.sintomas : '') %></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Diagnóstico (Opcional)</label>
                        <textarea name="diagnostico" class="form-control" rows="2"
                            placeholder="Dejar vacío si está pendiente"><%= typeof datos!== 'undefined'? datos.diagnostico : (typeof mascota!== 'undefined'? mascota.diagnostico : '') %></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success flex-grow-1 btn-lg shadow-sm fw-bold">
                            <i class="fa-solid fa-cloud-arrow-up me-1"></i> Guardar Mascota
                        </button>
                        <a href="/mascotas" class="btn btn-outline-secondary btn-lg">
                            <i class="fa-solid fa-xmark me-1"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>