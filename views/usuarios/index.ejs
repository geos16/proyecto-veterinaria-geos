<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-secondary"><i class="fa-solid fa-users me-2"></i>Personal</h2>
    <a href="/registro" class="btn btn-primary shadow-sm">
        <i class="fa-solid fa-user-plus me-1"></i> Registrar Veterinario
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% usuarios.forEach(staff => { %>
                    <tr>
                        <td class="ps-4 fw-bold text-primary"><%= staff.username %></td>
                        <td>
                            <span class="badge <%= staff.role === 'admin'? 'bg-danger' : 'bg-info' %> px-3">
                                <%= staff.role.toUpperCase() %>
                            </span>
                        </td>
                        <td>
                            <% if (staff.id === user.id) { %>
                                <span class="text-success small"><i class="fa-solid fa-circle-check me-1"></i> Tu Sesión</span>
                            <% } else { %>
                                <span class="text-muted small">Activo</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (staff.id!== user.id) { %>
                                <form action="/usuarios/borrar/<%= staff.id %>" method="POST" class="d-inline" id="form-borrar-staff-<%= staff.id %>">
                                    <button type="button" class="btn btn-sm btn-outline-danger shadow-sm" 
                                            onclick="confirmarEliminarStaff('<%= staff.id %>', '<%= staff.username %>')">
                                        <i class="fa-solid fa-user-slash me-1"></i> Eliminar
                                    </button>
                                </form>
                            <% } else { %>
                                <button class="btn btn-sm btn-light disabled" title="No puedes eliminarte a ti mismo">
                                    <i class="fa-solid fa-ban"></i> Bloqueado
                                </button>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
function confirmarEliminarStaff(id, username) {
    Swal.fire({
        title: '¿Revocar acceso a @' + username + '?',
        text: "Este veterinario ya no podrá ingresar al sistema de la clínica.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#e74c3c', // Rojo Geos
        cancelButtonColor: '#95a5a6',
        confirmButtonText: 'Sí, eliminar cuenta',
        cancelButtonText: 'Mantener acceso',
        reverseButtons: true,
        borderRadius: '15px'
    }).then((result) => {
        if (result.isConfirmed) {
            // Enviamos el formulario específico de este usuario
            document.getElementById('form-borrar-staff-' + id).submit();
        }
    })
}
</script>

<%- include('../partials/footer') %>